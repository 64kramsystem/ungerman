{
  "manifest_version": 2,
  "name": "Ungerman",
  "version": "1.0.0",
  "description": "When replying to a message whose subject already starts with 'AW: ', does not prefix anything (avoids 'AW: AW: ...' or 'Re: AW: ...' stacking).",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ungerman@64kramsystem.github.io",
      "strict_min_version": "91.0"
    }
  },
  "background": {
    "scripts": ["subject.js", "background.js"]
  },
  "permissions": [
    "compose"
  ]
}
